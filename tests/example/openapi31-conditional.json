{
  "openapi": "3.1.0",
  "info": {
    "title": "Conditional Schema Test",
    "version": "1.0.0"
  },
  "paths": {
    "/shipping": {
      "post": {
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "country": {
                    "type": "string"
                  },
                  "postalCode": {
                    "type": "string"
                  }
                },
                "if": {
                  "properties": {
                    "country": {
                      "const": "US"
                    }
                  }
                },
                "then": {
                  "properties": {
                    "postalCode": {
                      "pattern": "^[0-9]{5}(-[0-9]{4})?$"
                    }
                  }
                },
                "else": {
                  "properties": {
                    "postalCode": {
                      "pattern": "^[A-Z0-9 -]+$"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/product": {
      "post": {
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "productType": {
                    "type": "string"
                  },
                  "price": {
                    "type": "number"
                  },
                  "subscription": {
                    "type": "object",
                    "properties": {
                      "interval": {
                        "type": "string"
                      }
                    }
                  }
                },
                "if": {
                  "properties": {
                    "productType": {
                      "const": "subscription"
                    }
                  }
                },
                "then": {
                  "required": [
                    "subscription"
                  ]
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created"
          }
        }
      }
    }
  }
}
